---
// Inline, currentColor SVG icons. Soft, rounded, line-based.
// Usage: <Icon name="leaf" class="h-5 w-5" />
interface Props {
  name: string;
  class?: string;
  /** decorative icons are hidden from screen readers by default */
  title?: string;
}
const { name, class: className = "h-6 w-6", title } = Astro.props;

const paths: Record<string, string> = {
  // signature sprout / leaf motif
  leaf: `<path d="M12 21c0-6 0-9 0-9M12 12c5 0 8-3 8-8-5 0-8 3-8 8Zm0 0c-4 0-6.5-2.5-6.5-6.5C9 5.5 12 8 12 12Z"/>`,
  bloom: `<path d="M12 22v-7m0 0c3.6 0 6-2.4 6-6 0-1.2-.3-2.3-.8-3.2C16 7 14 8.6 13 11M12 15C9 15 7 13 7 10.5 9 11 11 12.6 12 15Zm0-7a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>`,
  heart: `<path d="M12 20S4 14.5 4 8.8C4 6.1 6.1 4 8.8 4c1.7 0 3.2.9 4 2.3C13.6 4.9 15.1 4 16.8 4 19.5 4 21.6 6.1 21.6 8.8 21.6 14.5 12 20 12 20Z"/>`,
  rings: `<circle cx="9" cy="13" r="6"/><circle cx="15" cy="11" r="6"/>`,
  shield: `<path d="M12 3.5 19 6v5.5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V6l7-2.5Z"/><path d="m9 11.8 2.2 2.2L15.2 10"/>`,
  video: `<rect x="3" y="6" width="13" height="12" rx="3.5"/><path d="m16 10.5 5-3v9l-5-3Z"/>`,
  clock: `<circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3 2"/>`,
  calendar: `<rect x="4" y="5.5" width="16" height="15" rx="3.5"/><path d="M4 10h16M8.5 3.5v4M15.5 3.5v4"/>`,
  mail: `<rect x="3" y="5.5" width="18" height="13" rx="3.5"/><path d="m4.5 8 6.4 4.4a2 2 0 0 0 2.2 0L19.5 8"/>`,
  check: `<path d="m5 12.5 4.5 4.5L19 7"/>`,
  "check-circle": `<circle cx="12" cy="12" r="8.5"/><path d="m8.5 12 2.4 2.4L15.8 9.5"/>`,
  "arrow-right": `<path d="M5 12h14m-6-6 6 6-6 6"/>`,
  "arrow-up-right": `<path d="M7 17 17 7M8 7h9v9"/>`,
  "chevron-down": `<path d="m6 9 6 6 6-6"/>`,
  menu: `<path d="M4 7h16M4 12h16M4 17h16"/>`,
  close: `<path d="m6 6 12 12M18 6 6 18"/>`,
  feather: `<path d="M20 4C11 4 4 11 4 20M20 4c0 7-4 12-11 13M20 4l-7 7M4 20l5-5"/>`,
  compass: `<circle cx="12" cy="12" r="8.5"/><path d="m14.5 9.5-1.2 4.8L8.5 15.5l1.2-4.8L14.5 9.5Z"/>`,
  "speech": `<path d="M5 5.5h14a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H10l-4 3.5V15.5H5a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2Z"/>`,
  // two overlapping speech bubbles – Paartherapie (inclusive of every relationship form)
  "speech2": `<path d="M3 5.6h10.5a1.8 1.8 0 0 1 1.8 1.8v4.3a1.8 1.8 0 0 1-1.8 1.8H7.8L4 16.6v-2.6a1.8 1.8 0 0 1-1-1.6V7.4a1.8 1.8 0 0 1 1.8-1.8Z"/><path d="M9.5 10.4h9.7a1.8 1.8 0 0 1 1.8 1.8v3.1a1.8 1.8 0 0 1-1.8 1.8v2.3l-3-2.3"/>`,
  // interconnected nodes – "systemisch denken"
  "systemic": `<circle cx="6" cy="7" r="2.2"/><circle cx="18" cy="7" r="2.2"/><circle cx="12" cy="17.5" r="2.2"/><path d="M8 8.2 10.6 15.4M16 8.2 13.4 15.4M8.2 7h7.6"/>`,
  "lock": `<rect x="5" y="10.5" width="14" height="9.5" rx="3"/><path d="M8 10.5V8a4 4 0 0 1 8 0v2.5"/>`,
};

const d = paths[name] ?? paths.leaf;
const isDecorative = !title;
---
<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={isDecorative ? "true" : undefined}
  role={isDecorative ? undefined : "img"}
  set:html={(title ? `<title>${title}</title>` : "") + d}
></svg>
