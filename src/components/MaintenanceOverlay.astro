---
import Icon from "@/components/Icon.astro";
import { site } from "@/data/site";
---

<main
  class="min-h-svh bg-forest-deep text-cream"
  aria-labelledby="maintenance-title"
>
  <div class="container-page flex min-h-svh flex-col">
    <header class="flex justify-center border-b border-white/10 py-5 sm:justify-start sm:py-6">
      <div class="flex items-center gap-3.5">
        <span
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-cream text-forest-deep"
          aria-hidden="true"
        >
          <Icon name="leaf" class="h-6 w-6" />
        </span>
        <span class="text-left">
          <strong class="block font-display text-base font-semibold text-cream sm:text-lg">
            {site.name}
          </strong>
          <span class="block font-display text-xs text-sage-soft sm:text-sm">
            Psychotherapie · Online
          </span>
        </span>
      </div>
    </header>

    <section class="flex flex-1 items-center justify-center py-12 text-center sm:py-16">
      <div class="mx-auto max-w-3xl">
        <span
          class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-white/15 bg-white/5 text-sage-soft sm:h-20 sm:w-20"
          aria-hidden="true"
        >
          <Icon name="leaf" class="h-8 w-8 sm:h-10 sm:w-10" />
        </span>

        <p class="mt-7 font-display text-sm font-semibold text-terracotta-light sm:text-base">
          Website im Aufbau
        </p>
        <h1
          id="maintenance-title"
          class="mt-4 text-balance font-display text-4xl font-medium leading-tight text-cream sm:text-5xl lg:text-6xl"
        >
          Diese Website ist noch in Bearbeitung.
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-pretty text-base leading-relaxed text-sage-soft sm:text-lg">
          Wir arbeiten gerade an den letzten Details. Die Website ist in Kürze
          für Sie verfügbar.
        </p>

        <div class="mx-auto mt-10 h-px w-20 bg-terracotta-light" aria-hidden="true"></div>
      </div>
    </section>

    <p class="border-t border-white/10 py-5 text-center font-display text-xs text-sage-soft sm:py-6 sm:text-sm">
      Online-Psychotherapie · Paartherapie · Sexualtherapie
    </p>
  </div>
</main>
