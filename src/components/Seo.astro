---
import { site } from "@/data/site";

interface Props {
  title: string;
  description: string;
  /** Optional copy tailored specifically to social share cards. */
  socialTitle?: string;
  socialDescription?: string;
  /** Path to an OG image in /public, or absolute URL. */
  image?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageType?: string;
  /** Set true on legal / utility pages you don't want indexed-as-primary. */
  noindex?: boolean;
  /** Prevent crawlers from following links, e.g. while the complete site is private. */
  nofollow?: boolean;
  /** Optional extra JSON-LD object(s) merged into the page. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  socialTitle,
  socialDescription,
  image = "/og-image-v3.jpg",
  imageAlt = `Social-Media-Vorschau der Online-Praxis von ${site.name}.`,
  imageWidth = 1200,
  imageHeight = 630,
  imageType = "image/jpeg",
  noindex = false,
  nofollow = false,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).href.replace(/\/$/, "") || site.url;
const ogImage = image.startsWith("http") ? image : new URL(image, site.url).href;

// Full title with practice name appended (avoids duplication on the home title).
const fullTitle = title.includes(site.name)
  ? title
  : `${title} | ${site.name}`;
const fullSocialTitle = socialTitle
  ? socialTitle.includes(site.name)
    ? socialTitle
    : `${socialTitle} | ${site.name}`
  : fullTitle;
const fullSocialDescription = socialDescription || description;

const ldBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!-- Primary meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta
  name="robots"
  content={`${noindex ? "noindex" : "index"}, ${nofollow ? "nofollow" : "follow"}`}
/>
<meta name="author" content={site.name} />
<meta name="theme-color" content="#3f5141" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content="de_DE" />
<meta property="og:title" content={fullSocialTitle} />
<meta property="og:description" content={fullSocialDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:secure_url" content={ogImage} />
<meta property="og:image:type" content={imageType} />
<meta property="og:image:width" content={String(imageWidth)} />
<meta property="og:image:height" content={String(imageHeight)} />
<meta property="og:image:alt" content={imageAlt} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullSocialTitle} />
<meta name="twitter:description" content={fullSocialDescription} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={imageAlt} />

<!-- Structured data -->
{
  ldBlocks.map((block) => (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(block)}
    />
  ))
}
