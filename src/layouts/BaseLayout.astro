---
import "@/styles/global.css";
import { isSiteInProgress, site } from "@/data/site";
import { getSocialMeta, socialImage } from "@/data/social";
import Seo from "@/components/Seo.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import MaintenanceOverlay from "@/components/MaintenanceOverlay.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, image, noindex, jsonLd } = Astro.props;
const maintenanceTitle = `Website in Bearbeitung | ${site.name}`;
const maintenanceDescription = `Die Website von ${site.name} befindet sich derzeit in Bearbeitung.`;
const socialMeta = isSiteInProgress ? undefined : getSocialMeta(Astro.url.pathname);
---
<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon-48x48.png" sizes="48x48" type="image/png" />
    <link rel="icon" href="/favicon-96x96.png" sizes="96x96" type="image/png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Seo
      title={isSiteInProgress ? maintenanceTitle : title}
      description={isSiteInProgress ? maintenanceDescription : description}
      socialTitle={socialMeta?.title}
      socialDescription={socialMeta?.description}
      image={image || socialImage.path}
      imageAlt={socialImage.alt}
      imageWidth={socialImage.width}
      imageHeight={socialImage.height}
      imageType={socialImage.type}
      noindex={noindex || isSiteInProgress}
      nofollow={isSiteInProgress}
      jsonLd={jsonLd}
    />
  </head>
  <body class="min-h-screen overflow-x-hidden">
    {
      isSiteInProgress ? (
        <MaintenanceOverlay />
      ) : (
        <>
          <a
            href="#main"
            class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-full focus:bg-forest focus:px-5 focus:py-2.5 focus:font-display focus:text-sm focus:text-cream"
          >
            Zum Inhalt springen
          </a>
          <Header />
          <main id="main">
            <slot />
          </main>
          <Footer />
        </>
      )
    }

    <script>
      // Gentle scroll-reveal. Respects prefers-reduced-motion (handled in CSS).
      const els = document.querySelectorAll<HTMLElement>(".reveal");
      if (
        els.length &&
        !window.matchMedia("(prefers-reduced-motion: reduce)").matches &&
        "IntersectionObserver" in window
      ) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
