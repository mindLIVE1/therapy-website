---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Blob from "@/components/Blob.astro";

interface Props {
  title: string;
  description: string;
  heading: string;
  updated?: string;
}
const { title, description, heading, updated } = Astro.props;
---
<BaseLayout title={title} description={description} noindex>
  <section class="relative overflow-hidden">
    <Blob color="sage" class="right-[-7rem] top-[-7rem] h-80 w-80" />
    <div class="container-page py-14 lg:py-16">
      <h1 class="text-4xl sm:text-5xl">{heading}</h1>
      {updated && <p class="mt-3 text-sm text-taupe-soft">Stand: {updated}</p>}
    </div>
  </section>

  <section class="container-page pb-16">
    <div class="prose-legal max-w-3xl">
      <slot />
    </div>
  </section>
</BaseLayout>

<style is:global>
  .prose-legal h2 {
    font-size: 1.4rem;
    margin-top: 2.4rem;
    margin-bottom: 0.6rem;
  }
  .prose-legal h3 {
    font-size: 1.1rem;
    margin-top: 1.6rem;
    margin-bottom: 0.4rem;
  }
  .prose-legal p,
  .prose-legal ul {
    margin-bottom: 1rem;
    line-height: 1.75;
    color: var(--color-taupe-ink);
  }
  .prose-legal ul {
    list-style: disc;
    padding-left: 1.4rem;
  }
  .prose-legal li {
    margin-bottom: 0.35rem;
  }
  .prose-legal a {
    color: var(--color-forest);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-legal .placeholder {
    background: var(--color-clay-soft);
    color: var(--color-clay-deep);
    padding: 0 0.35em;
    border-radius: 0.3rem;
    font-weight: 600;
  }
</style>
