---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import ImagePlaceholder from "@/components/ImagePlaceholder.astro";
import Blob from "@/components/Blob.astro";
import Icon from "@/components/Icon.astro";
import { Image } from "astro:assets";
import { site, services, isDemo } from "@/data/site";
import elenaPhoto from "@/assets/elena-roehrborn.webp";
import heroRaum from "@/assets/hero-raum.png";
import pflanzeImg from "@/assets/pflanze.png";
import momentImg from "@/assets/moment-natur.png";

const heroChips = [
  { icon: "lock", label: "100 % vertraulich & DSGVO-konform" },
  { icon: "video", label: "Per Video, Telefon oder Text, deutschlandweit" },
];

const themes = [
  "Anhaltender Stress, Erschöpfung oder das Gefühl, ständig funktionieren zu müssen",
  "Ängste, Sorgen oder Panik",
  "Niedergeschlagenheit, Selbstzweifel oder innere Leere",
  "Konflikte, Distanz oder Sprachlosigkeit in der Partnerschaft",
  "Fragen zu Sexualität, Intimität oder unterschiedlichen Bedürfnissen",
  "Lebenskrisen, Veränderungen oder schwierige Entscheidungen",
];

const steps = [
  {
    icon: "speech",
    title: "Kontakt aufnehmen",
    text: "Schreiben Sie mir über das Kontaktformular oder per E-Mail. Ich melde mich zeitnah persönlich zurück, beantworte offene Fragen und wir finden gemeinsam einen passenden Termin. Oft auch kurzfristig.",
  },
  {
    icon: "compass",
    title: "Erstgespräch & Orientierung",
    text: "In der ersten Sitzung lernen wir uns kennen und widmen uns bereits Ihrem Anliegen. Wir klären Ihre aktuelle Situation, Ihre Ziele und Ihren Auftrag an die Therapie. Oft entstehen dabei schon erste neue Perspektiven und spürbare Entlastung.",
  },
  {
    icon: "bloom",
    title: "Verstehen. Verändern. Festigen.",
    text: "Gemeinsam verstehen wir die Zusammenhänge hinter Ihren Belastungen, erkennen wiederkehrende Muster und entwickeln neue Handlungsmöglichkeiten. Schritt für Schritt entsteht mehr Klarheit, Selbstvertrauen und nachhaltige Veränderung.",
  },
];

const faqs = [
  {
    q: "Wie schnell bekomme ich einen Termin?",
    a: "In der Regel kann ich kurzfristig Termine anbieten. Schreiben Sie mir einfach über das Kontaktformular oder per E-Mail. Ich melde mich zeitnah persönlich bei Ihnen zurück und wir finden gemeinsam einen passenden Termin.",
  },
  {
    q: "Muss ich genau wissen, worüber ich sprechen möchte?",
    a: "Nein. Viele Menschen kommen mit dem Gefühl, dass etwas belastet, ohne es genau benennen zu können. Gemeinsam schaffen wir Schritt für Schritt Klarheit. Sie müssen nichts vorbereitet haben.",
  },
  {
    q: "Was passiert in der ersten Sitzung?",
    a: "In der ersten Sitzung lernen wir uns kennen und besprechen Ihr Anliegen ausführlich. Gemeinsam klären wir, was Sie beschäftigt, welche Ziele Sie haben und wie eine passende Zusammenarbeit aussehen kann. Bereits die erste Sitzung ist eine vollständige therapeutische Sitzung.",
  },
  {
    q: "Kann ich auch aus dem Ausland teilnehmen?",
    a: "Ja. Solange Sie sich während der Sitzung an einem ruhigen Ort mit stabiler Internetverbindung befinden, können Sie auch aus dem Ausland teilnehmen.",
  },
  {
    q: "Ist Online-Therapie genauso wirksam wie vor Ort?",
    a: "Ja. Studien zeigen, dass Online-Psychotherapie bei vielen Anliegen genauso wirksam sein kann wie eine Therapie vor Ort. Viele Menschen erleben es sogar als hilfreich, sich in ihrer vertrauten Umgebung zu öffnen.",
  },
  {
    q: "Brauche ich eine Diagnose oder Überweisung?",
    a: "Nein. Sie benötigen weder eine Diagnose noch eine Überweisung. Sie können sich jederzeit aus eigener Entscheidung Unterstützung holen – auch dann, wenn Sie sich einfach mehr Orientierung, Entlastung oder persönliche Entwicklung wünschen.",
  },
];

// Structured data for search engines (a psychotherapy practice).
const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["MedicalBusiness", "ProfessionalService"],
  name: `${site.name} – ${site.tagline}`,
  description:
    "Online-Praxis für Psychotherapie, Paar- und Sexualtherapie. Vertrauliche, einfühlsame Begleitung per Video – deutschlandweit.",
  url: site.url,
  email: site.email,
  image: new URL("/og-image-v3.jpg", site.url).href,
  areaServed: "DE",
  availableLanguage: "de",
  medicalSpecialty: "Psychiatric",
  founder: {
    "@type": "Person",
    name: site.name,
    jobTitle: site.role,
  },
  knowsAbout: ["Psychotherapie", "Paartherapie", "Sexualtherapie", "Online-Therapie"],
};
---
<BaseLayout
  title={`Online-Psychotherapie, Paar- & Sexualtherapie | ${site.name}`}
  description={`Vertrauliche Online-Psychotherapie, Paar- und Sexualtherapie bei ${site.name}. Einfühlsame, professionelle Begleitung per Video – deutschlandweit und ganz bequem von zu Hause.`}
  jsonLd={jsonLd}
>
  <!-- ───────────────────────── Hero ───────────────────────── -->
  <section class="container-page pt-8 sm:pt-12">
    <div class="reveal relative isolate overflow-hidden rounded-[2.5rem] shadow-[var(--shadow-soft)]">
      <!-- background photo -->
      <Image
        src={heroRaum}
        alt="Ruhiger, warm eingerichteter Raum mit Sessel und Pflanzen"
        widths={[640, 960, 1280, 1600]}
        sizes="(min-width: 1280px) 1200px, 100vw"
        class="absolute inset-0 -z-10 h-full w-full object-cover object-right"
      />
      <!-- legibility scrim: cream on the text side -->
      <div
        class="absolute inset-0 -z-10 bg-gradient-to-b from-cream/85 via-cream/70 to-cream/70 sm:bg-gradient-to-r sm:from-cream sm:from-30% sm:via-cream/85 sm:to-transparent"
      ></div>

      <div class="max-w-xl px-6 py-14 sm:px-10 sm:py-20 lg:px-14 lg:py-24">
        <p class="eyebrow">Online-Psychotherapie · deutschlandweit</p>
        <h1 class="mt-5 text-4xl sm:text-5xl lg:text-[3.4rem]">
          Ein geschützter Raum für das,<br class="hidden sm:block" />
          <span class="text-forest">was Sie gerade bewegt.</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-taupe-ink/90">
          Online-Psychotherapie, Paartherapie &amp; Sexualtherapie – professionell,
          einfühlsam und vertraulich. Ich begleite Sie bei Selbstwertthemen,
          Beziehungsproblemen, Sexualität, Krisen, emotionalen Belastungen und
          persönlicher Entwicklung.
        </p>
        <p class="mt-4 leading-relaxed text-taupe-ink/80">
          Es braucht Mut, sich Unterstützung zu suchen. Und manchmal ist genau
          dieser Schritt der Beginn einer nachhaltigen Veränderung.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/kontakt#termin" class="btn btn-primary">
            Erstgespräch anfragen
          </a>
          <a href="/kontakt" class="btn btn-outline">
            <Icon name="mail" class="h-5 w-5" />
            Kontakt aufnehmen
          </a>
        </div>

        <ul class="mt-9 flex flex-wrap gap-x-6 gap-y-3">
          {
            heroChips.map((chip) => (
              <li class="inline-flex items-center gap-2 text-sm font-medium text-taupe-ink/90">
                <span class="flex h-7 w-7 items-center justify-center rounded-full bg-cream/80 text-forest ring-1 ring-forest/10">
                  <Icon name={chip.icon} class="h-4 w-4" />
                </span>
                {chip.label}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ──────────────────── Therapieangebote ─────────────────── -->
  <section class="container-page py-16 sm:py-20">
    <SectionHeading
      eyebrow="Therapieangebote"
      title="Das passende Therapieangebot für Ihr Anliegen"
      lead="Ob Sie sich selbst besser verstehen möchten, Ihre Beziehung stärken oder Fragen rund um Sexualität klären wollen – gemeinsam finden wir einen Weg, der zu Ihnen passt."
      align="center"
      class="reveal"
    />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        services.map((service, i) => (
          <div class="reveal" style={`--reveal-delay:${i * 90}ms`}>
            <ServiceCard service={service} feature />
          </div>
        ))
      }
    </div>
    <div class="reveal mt-10 text-center">
      <a href="/therapieangebote" class="btn btn-outline">
        Alle Angebote im Überblick
        <Icon name="arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </section>

  <!-- ─────────────────── Vielleicht kennen Sie das ──────────── -->
  <section class="relative overflow-hidden bg-sage-mist py-16 sm:py-24">
    <Blob color="sage" class="right-[-8rem] bottom-[-6rem] h-80 w-80" />
    <div class="container-page grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="reveal relative order-2 lg:order-1">
        <ImagePlaceholder
          shape="rounded"
          ratio="6/5"
          tone="sand"
          src={pflanzeImg}
          alt="Sonnendurchflutetes Zimmer mit Pflanze"
        />
      </div>
      <div class="reveal order-1 lg:order-2">
        <SectionHeading
          eyebrow="Vielleicht erkennen Sie sich hier wieder"
          title="Der erste Schritt beginnt oft mit dem Gefühl, dass etwas anders werden darf"
          lead="Sie brauchen keine Diagnose, keine perfekte Erklärung und keinen „triftigen Grund“, um sich Unterstützung zu erlauben. Oft reicht das Gefühl, dass etwas nicht mehr stimmig ist. Wenn Sie sich in einem oder mehreren dieser Punkte wiederfinden, begleite ich Sie gerne."
        />
        <ul class="mt-7 grid gap-3 sm:grid-cols-1">
          {
            themes.map((t) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-forest/10 text-forest">
                  <Icon name="leaf" class="h-4 w-4" />
                </span>
                <span class="text-taupe-ink/90">{t}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ───────────────────── Über-mich Teaser ────────────────── -->
  <section class="container-page py-16 sm:py-24">
    <div class="grid items-center gap-12 lg:grid-cols-[0.85fr_1.15fr]">
      <div class="reveal relative mx-auto w-full max-w-sm">
        <Blob color="clay" class="left-[-4rem] top-[-3rem] h-64 w-64" />
        <ImagePlaceholder
          shape="circle"
          tone="sage"
          src={isDemo ? undefined : elenaPhoto}
          alt={site.name}
          position="46% 24%"
        />
      </div>
      <div class="reveal">
        <p class="eyebrow">Schön, dass Sie hier sind</p>
        <h2 class="mt-4 text-3xl sm:text-4xl">
          Ich begleite Menschen mit Wärme, Klarheit und Struktur
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-taupe-ink/85">
          Viele Menschen wünschen sich jemanden, der wirklich zuhört und
          gleichzeitig dabei hilft, Gedanken zu ordnen und neue Perspektiven zu
          entwickeln. Genauso verstehe ich Therapie.
        </p>
        <p class="mt-4 leading-relaxed text-taupe-ink/85">
          Ich begegne Ihnen auf Augenhöhe: empathisch, wertschätzend und ohne
          Urteil. Gleichzeitig arbeite ich klar, strukturiert und
          lösungsorientiert. Gemeinsam verstehen wir, was Sie belastet, erkennen
          wiederkehrende Muster und entwickeln Schritt für Schritt Wege, die zu
          Ihnen und Ihrem Leben passen.
        </p>
        <p class="mt-4 leading-relaxed text-taupe-ink/85">
          Sie bestimmen das Tempo. Ich sorge für einen sicheren Rahmen,
          Orientierung und einen klaren roten Faden, damit Veränderung nicht
          überwältigend wirkt, sondern möglich wird.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/ueber-mich" class="btn btn-forest">
            Mehr über mich &amp; meinen Ansatz
          </a>
          <a href="/kontakt#termin" class="link-arrow self-center">
            Lieber direkt anfragen
            <Icon name="arrow-right" class="h-4 w-4" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Ablauf ──────────────────────── -->
  <section class="relative overflow-hidden bg-sand-deep/50 py-16 sm:py-24">
    <div class="container-page">
      <SectionHeading
        eyebrow="So einfach beginnt es"
        title="In drei klaren Schritten"
        lead="Der erste Schritt muss sich nicht groß anfühlen. Wir beginnen dort, wo Sie gerade stehen, in Ihrem Tempo und ohne Druck."
        align="center"
        class="reveal"
      />
      <ol class="mt-14 grid gap-8 md:grid-cols-3">
        {
          steps.map((step, i) => (
            <li class="reveal relative" style={`--reveal-delay:${i * 110}ms`}>
              <div class="flex h-full flex-col rounded-[2rem] border border-line-soft bg-cream p-7 shadow-[var(--shadow-card)]">
                <div class="flex items-center gap-4">
                  <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-forest text-cream">
                    <Icon name={step.icon} class="h-6 w-6" />
                  </span>
                  <span class="font-display text-sm font-semibold uppercase tracking-[0.16em] text-clay-deep">
                    Schritt {i + 1}
                  </span>
                </div>
                <h3 class="mt-5 text-xl">{step.title}</h3>
                <p class="mt-3 leading-relaxed text-taupe-ink/85">{step.text}</p>
              </div>
            </li>
          ))
        }
      </ol>
      <div class="reveal mt-12 text-center">
        <a href="/honorar" class="link-arrow">
          Mehr zu Ablauf &amp; Honorar
          <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- ──────────────────── Mid-page CTA band ────────────────── -->
  <section class="container-page py-16 sm:py-20">
    <div class="reveal relative overflow-hidden rounded-[2.75rem] bg-forest px-8 py-14 text-cream shadow-[var(--shadow-soft)] sm:px-14">
      <span aria-hidden="true" class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-sage/20 blur-2xl"></span>
      <span aria-hidden="true" class="pointer-events-none absolute -bottom-20 -left-10 h-64 w-64 rounded-full bg-clay/20 blur-2xl"></span>
      <div class="relative grid items-center gap-8 lg:grid-cols-[1.4fr_1fr]">
        <div>
          <h2 class="text-cream text-3xl sm:text-4xl">
            Sie müssen das nicht allein tragen
          </h2>
          <p class="mt-4 max-w-xl text-lg leading-relaxed text-cream/80">
            Schreiben Sie mir – in Ihren Worten, ohne Vorbereitung. Ich melde
            mich zeitnah persönlich bei Ihnen zurück.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row lg:justify-end">
          <a href="/kontakt#termin" class="btn btn-light">Erstgespräch anfragen</a>
          <a href="/kontakt" class="btn btn-outline border-cream/40 !text-cream hover:!bg-white/10">
            Kontakt aufnehmen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── FAQ ─────────────────────────── -->
  <section class="container-page py-16 sm:py-20">
    <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr]">
      <div class="reveal lg:sticky lg:top-28 lg:self-start">
        <SectionHeading
          eyebrow="Häufige Fragen"
          title="Häufige Fragen – kurz beantwortet"
          lead="Ihre Frage war nicht dabei? Schreiben Sie mir gerne unverbindlich. Ich beantworte Ihre Fragen persönlich und melde mich in der Regel innerhalb kurzer Zeit zurück."
        />
        <a href="/kontakt#termin" class="link-arrow mt-6 inline-flex">
          Termin anfragen
          <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>
      <div class="reveal divide-y divide-line">
        {
          faqs.map((faq) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg font-semibold text-ink marker:hidden">
                {faq.q}
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-sage-mist text-forest transition-transform duration-300 group-open:rotate-45">
                  <Icon name="arrow-right" class="h-4 w-4 rotate-[-45deg] group-open:rotate-0" />
                </span>
              </summary>
              <p class="mt-3 pr-12 leading-relaxed text-taupe-ink/85">{faq.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─────────────────── Final warm CTA band ───────────────── -->
  <section class="relative overflow-hidden">
    <div class="container-page py-8 sm:py-12">
      <div class="reveal grid items-stretch gap-0 overflow-hidden rounded-[2.75rem] shadow-[var(--shadow-soft)] lg:grid-cols-2">
        <div class="relative min-h-[18rem]">
          <ImagePlaceholder
            shape="rounded"
            tone="clay"
            ratio="1/1"
            src={momentImg}
            alt="Sonnenuntergang über einem Pfad am Meer"
            class="!rounded-none h-full"
          />
        </div>
        <div class="flex flex-col justify-center bg-clay px-8 py-12 text-cream sm:px-12">
          <p class="font-display text-sm font-semibold uppercase tracking-[0.16em] text-cream/80">
            Ich freue mich auf Sie
          </p>
          <h2 class="mt-4 text-cream text-3xl sm:text-4xl">
            Lassen Sie uns ins Gespräch kommen
          </h2>
          <p class="mt-5 leading-relaxed text-cream/85">
            Wenn Sie spüren, dass jetzt ein guter Moment ist: Ich nehme mir Zeit
            für Sie. Der erste Schritt ist kleiner, als er sich anfühlt.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/kontakt#termin" class="btn btn-light">Termin anfragen</a>
            <a href={`mailto:${site.email}`} class="btn btn-outline border-cream/40 !text-cream hover:!bg-white/10">
              <Icon name="mail" class="h-5 w-5" />
              Per E-Mail schreiben
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
