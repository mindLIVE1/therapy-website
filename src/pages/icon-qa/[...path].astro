---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";

export function getStaticPaths() {
  const enabled =
    import.meta.env.DEV || process.env.ENABLE_DEV_ROUTES === "true";

  return enabled ? [{ params: { path: undefined } }] : [];
}

const icons = [
  "leaf",
  "bloom",
  "heart",
  "rings",
  "shield",
  "video",
  "clock",
  "calendar",
  "mail",
  "check",
  "check-circle",
  "arrow-right",
  "arrow-up-right",
  "chevron-down",
  "menu",
  "close",
  "feather",
  "compass",
  "speech",
  "speech2",
  "systemic",
  "lock",
];
---

<BaseLayout
  title="Icon QA"
  description="Interne Übersicht zur visuellen Prüfung der Website-Icons."
  noindex
>
  <section class="container-page py-12">
    <h1 class="text-3xl">Icon QA</h1>
    <div class="mt-8 grid gap-5" style="grid-template-columns:repeat(6,minmax(0,1fr));">
      {
        icons.map((name) => (
          <article class="rounded-3xl border border-line-soft bg-sand p-5 text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-forest text-cream">
              <Icon name={name} class="h-7 w-7" />
            </div>
            <p class="mt-3 font-display text-sm font-semibold">{name}</p>
            <div class="mt-4 flex items-center justify-center gap-4 text-forest">
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-sage-mist">
                <Icon name={name} class="h-4 w-4" />
              </span>
              <Icon name={name} class="h-5 w-5" />
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
