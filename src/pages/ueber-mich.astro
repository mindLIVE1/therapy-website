---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ImagePlaceholder from "@/components/ImagePlaceholder.astro";
import Blob from "@/components/Blob.astro";
import Icon from "@/components/Icon.astro";
import { site, isDemo } from "@/data/site";
import elenaPhoto from "@/assets/elena-roehrborn.webp";
import arbeitsplatzImg from "@/assets/arbeitsplatz.png";

const values = [
  {
    icon: "systemic",
    title: "Systemisch denken",
    text: "Wir betrachten nicht nur Symptome, sondern die Zusammenhänge zwischen Beziehungen, Erfahrungen, Gedanken und Gefühlen. Nicht nur Probleme stehen im Mittelpunkt, sondern auch das, was bereits in Ihnen steckt.",
  },
  {
    icon: "heart",
    title: "Auf Augenhöhe",
    text: "Sie sind Expertin oder Experte für Ihr Leben. Ich begegne Ihnen ohne Belehrung – als Mensch, nicht als Diagnose.",
  },
  {
    icon: "lock",
    title: "Diskret & geschützt",
    text: "Schweigepflicht und ein sicherer Rahmen sind selbstverständlich. Was Sie mir anvertrauen, bleibt bei mir.",
  },
  {
    icon: "bloom",
    title: "Individuell & in Ihrem Tempo",
    text: "Jeder Mensch bringt seine eigene Geschichte mit. Deshalb gibt es bei mir keine Standardlösungen. Sie bestimmen, wie schnell wir gehen und worüber wir sprechen, ohne Druck.",
  },
  {
    icon: "compass",
    title: "Klar & strukturiert",
    text: "Einfühlsames Zuhören und ein klares Vorgehen schließen sich nicht aus. Wir wissen gemeinsam, wohin wir gehen.",
  },
];

const onlineBenefits = [
  "bequem von zu Hause",
  "keine Anfahrt",
  "flexible Termine",
  "deutschland- & europaweit",
  "Deutsch & Englisch",
  "vertraute Umgebung",
  "leichter in den Alltag integrierbar",
];

const credentials = [
  "Master in Klinischer Psychologie",
  "10 Jahre psychologische Berufserfahrung",
  "Psychotherapieerlaubnis nach dem HeilprG",
  "systemische Paar- & Sexualtherapie",
  "Deutschland- & europaweit online",
  "Deutsch & Englisch",
  "verschlüsselte Videositzungen",
  "Flexible Terminvereinbarung",
  "wertschätzend & urteilsfrei",
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.name,
  jobTitle: site.role,
  url: new URL("/ueber-mich", site.url).href,
  worksFor: { "@type": "MedicalBusiness", name: `${site.name} – ${site.tagline}` },
  knowsLanguage: ["de", "en"],
};
---
<BaseLayout
  title={`Über mich – ${site.name}`}
  description={`Lernen Sie ${site.name} kennen – Klinische Psychologin (M.Sc.) und Heilpraktikerin für Psychotherapie. Werdegang, therapeutischer Ansatz und was Sie in der Zusammenarbeit erwartet.`}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <Blob color="sage" class="right-[-7rem] top-[-6rem] h-96 w-96" />
    <Blob color="clay" class="left-[-8rem] bottom-[-4rem] h-72 w-72" />
    <div class="container-page grid items-center gap-12 py-16 lg:grid-cols-[0.9fr_1.1fr] lg:py-24">
      <div class="reveal relative mx-auto w-full max-w-sm">
        <ImagePlaceholder
          shape="blob"
          ratio="4/5"
          tone="sage"
          src={isDemo ? undefined : elenaPhoto}
          alt={`Porträt von ${site.name}`}
          position="46% 22%"
        />
      </div>
      <div class="reveal">
        <p class="eyebrow">Schön, dass Sie hier sind</p>
        <h1 class="mt-5 text-4xl sm:text-5xl">Die Person hinter der Therapie</h1>
        <p class="mt-6 text-lg leading-relaxed text-taupe-ink/85">
          Mein Name ist {site.name}. Ich bin Klinische Psychologin (M.Sc.),
          Heilpraktikerin für Psychotherapie und systemische Paartherapeutin
          sowie Sexualtherapeutin.
        </p>
        <p class="mt-4 leading-relaxed text-taupe-ink/85">
          Seit über zehn Jahren begleite ich Kinder, Jugendliche und Erwachsene
          in unterschiedlichen psychologischen und therapeutischen Kontexten.
          Heute arbeite ich ausschließlich online und unterstütze Menschen
          deutschland- und europaweit in deutscher und englischer Sprache.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/kontakt#termin" class="btn btn-primary">Erstgespräch anfragen</a>
          <a href="/therapieangebote" class="btn btn-outline">Meine Angebote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Werdegang -->
  <section class="container-page py-14 sm:py-20">
    <div class="grid gap-12 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="reveal max-w-2xl">
        <SectionHeading title="Mein Weg zu dieser Arbeit" eyebrow="Hintergrund" />
        <p class="mt-6 text-lg leading-relaxed text-taupe-ink/85">
          Mich hat schon immer fasziniert, wie Menschen Krisen bewältigen,
          Beziehungen gestalten und trotz schwieriger Erfahrungen wieder Hoffnung
          und Lebensfreude entwickeln können.
        </p>
        <p class="mt-4 leading-relaxed text-taupe-ink/85">
          Diese Neugier führte mich zunächst zum Studium der Klinischen
          Psychologie und später in die psychotherapeutische Arbeit. Mit den
          Jahren wurde mir immer deutlicher, dass nachhaltige Veränderung dort
          entsteht, wo Menschen sich verstanden, angenommen und gleichzeitig
          ehrlich begleitet fühlen.
        </p>
        <p class="mt-4 leading-relaxed text-taupe-ink/85">
          Deshalb verbinde ich in meiner Arbeit Empathie mit Klarheit, Struktur
          und einem systemischen Blick auf den Menschen und seine Beziehungen.
        </p>
      </div>
      <figure class="reveal relative self-start rounded-[2rem] bg-forest p-8 text-cream sm:p-10">
        <Icon name="feather" class="h-8 w-8 text-sage-soft" />
        <blockquote class="mt-4 font-display text-xl leading-snug text-cream">
          „Veränderung beginnt dort, wo sich jemand wirklich verstanden fühlt.“
        </blockquote>
      </figure>
    </div>
  </section>

  <!-- Warum Online-Therapie -->
  <section class="relative overflow-hidden bg-sand-deep/50 py-14 sm:py-20">
    <Blob color="sage" class="right-[-7rem] top-[-5rem] h-80 w-80" />
    <div class="container-page">
      <SectionHeading
        eyebrow="Warum online"
        title="Warum Online-Therapie?"
        lead="Viele Menschen erleben Online-Therapie inzwischen als besonders angenehm."
        class="reveal"
      />
      <ul class="reveal mt-8 flex flex-wrap gap-3">
        {onlineBenefits.map((b) => (
          <li class="inline-flex items-center gap-2 rounded-full border border-line-soft bg-cream px-5 py-2.5 text-taupe-ink/90 shadow-sm">
            <Icon name="check" class="h-4 w-4 text-forest" />
            {b}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Ansatz / Werte -->
  <section class="relative overflow-hidden bg-sage-mist py-14 sm:py-24">
    <div class="container-page">
      <SectionHeading
        eyebrow="Mein Ansatz"
        title="Wie ich arbeite"
        align="center"
        class="reveal"
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {values.map((v, i) => (
          <div class="reveal flex gap-5 rounded-[2rem] border border-line-soft bg-cream p-7 shadow-[var(--shadow-card)]" style={`--reveal-delay:${i * 80}ms`}>
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-forest text-cream">
              <Icon name={v.icon} class="h-6 w-6" />
            </span>
            <div>
              <h3 class="text-lg">{v.title}</h3>
              <p class="mt-2 leading-relaxed text-taupe-ink/85">{v.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Persönliche Note -->
  <section class="container-page py-14 sm:py-20">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="reveal relative mx-auto w-full max-w-md">
        <ImagePlaceholder
          shape="rounded"
          ratio="3/2"
          tone="sand"
          src={arbeitsplatzImg}
          alt="Ruhiger Arbeitsplatz mit Eukalyptus, Notizbuch und Sessel"
        />
      </div>
      <div class="reveal">
        <SectionHeading
          eyebrow="Abseits der Praxis"
          title="Ein paar Worte zu mir & meinem Hintergrund"
        />
        <p class="mt-6 leading-relaxed text-taupe-ink/85">
          Als Tochter einer Chilenin und mit einem Teil meiner Kindheit und
          Jugend in Frankreich habe ich früh erlebt, wie unterschiedlich Menschen
          leben, denken und fühlen können. Diese Offenheit prägt auch meine
          therapeutische Arbeit.
        </p>
        <p class="mt-4 leading-relaxed text-taupe-ink/85">
          Ich begegne Menschen unabhängig von ihrer Geschichte, ihrer Identität
          oder ihrer Lebensform mit Neugier, Respekt und Wertschätzung. Kraft
          finde ich selbst in der Natur, beim Reisen, guten Gesprächen und ruhigen
          Momenten. Vielleicht ist es genau diese Mischung aus Gelassenheit und
          Klarheit, die viele Menschen in meiner Arbeit schätzen.
        </p>
        <a href="/kontakt#termin" class="link-arrow mt-6 inline-flex">
          Lernen wir uns kennen
          <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- Das erwartet Sie -->
  <section class="container-page pb-6">
    <div class="reveal rounded-[2.5rem] border border-line-soft bg-sand p-8 shadow-[var(--shadow-card)] sm:p-12">
      <SectionHeading eyebrow="Auf einen Blick" title="Das erwartet Sie" />
      <ul class="mt-8 grid gap-x-8 gap-y-4 sm:grid-cols-2 lg:grid-cols-3">
        {credentials.map((c) => (
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-forest/10 text-forest">
              <Icon name="check" class="h-4 w-4" />
            </span>
            <span class="text-taupe-ink/90">{c}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="container-page py-14">
    <div class="reveal relative overflow-hidden rounded-[2.75rem] bg-forest px-8 py-12 text-cream shadow-[var(--shadow-soft)] sm:px-14">
      <span aria-hidden="true" class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-sage/20 blur-2xl"></span>
      <div class="relative flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
        <h2 class="text-cream text-2xl sm:text-3xl">Ich freue mich darauf, Sie kennenzulernen</h2>
        <div class="flex flex-wrap gap-3">
          <a href="/kontakt#termin" class="btn btn-light">Termin anfragen</a>
          <a href="/kontakt" class="btn btn-outline border-cream/40 !text-cream hover:!bg-white/10">Kontakt aufnehmen</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
